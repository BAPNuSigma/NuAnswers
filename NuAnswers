import random

class AccountingFinanceTutor:
    def __init__(self):
        self.hints_given = 0
        self.max_hints = 3
        self.student_progress = {}
        
        # Common encouraging phrases
        self.encouragement_phrases = [
            "You're on the right track!",
            "That's a good start. Let's think about this further.",
            "You're getting closer!",
            "Good effort! Let's break this down step by step.",
            "Almost there! Consider one more aspect..."
        ]
        
        # Topic-specific guidance templates
        self.topic_hints = {
            "accounting_equation": [
                "Remember the basic accounting equation: Assets = Liabilities + Equity",
                "Think about what changes on each side of the equation when a transaction occurs",
                "Consider how this transaction affects the company's assets and liabilities"
            ],
            "financial_ratios": [
                "Start by identifying which financial statements you need",
                "Consider what this ratio is trying to measure",
                "Think about the relationship between the numerator and denominator"
            ]
        }
        
        # Adding structured question sequences for different topics
        self.question_sequences = {
            "accounting_equation": [
                "Can you tell me what the basic accounting equation is?",
                "How do assets relate to liabilities and equity in this equation?",
                "When we make a transaction, what two parts of the equation are affected?"
            ],
            "financial_statements": [
                "What are the main financial statements we use in accounting?",
                "How does the income statement connect to the balance sheet?",
                "What's the purpose of the cash flow statement?"
            ],
            "financial_ratios": [
                "What aspect of the company's performance are we trying to measure?",
                "Which financial statements would contain the numbers we need?",
                "How would we calculate this ratio step by step?"
            ]
        }
        
        # Track current question sequence and progress
        self.current_topic = None
        self.current_question_index = 0
        self.student_understanding = {}

    def greet_student(self):
        """Initial greeting and session setup"""
        welcome_message = """
        Hello! I'm your Accounting & Finance Tutor. I'm here to help you understand 
        concepts and work through problems. Remember, I won't give you direct answers, 
        but I'll guide you to find them yourself.
        
        How can I help you today?
        """
        return welcome_message

    def start_topic_discussion(self, topic):
        """Initiates a new topic discussion with the first question"""
        if topic in self.question_sequences:
            self.current_topic = topic
            self.current_question_index = 0
            return self.question_sequences[topic][0]
        return "Let's start with the basics. What would you like to understand about this topic?"

    def evaluate_response(self, student_response, topic):
        """Evaluates response and determines next question or guidance needed"""
        if not self.current_topic:
            return self.start_topic_discussion(topic)
            
        # Analyze student response and provide appropriate feedback
        response_quality = self._assess_response(student_response)
        
        if response_quality == "good":
            self.current_question_index += 1
            if self.current_question_index < len(self.question_sequences[self.current_topic]):
                return (f"{random.choice(self.encouragement_phrases)} "
                       f"{self.question_sequences[self.current_topic][self.current_question_index]}")
            else:
                return "Excellent! You've shown good understanding of this topic. Would you like to try a practice problem?"
        else:
            return self._provide_guided_hint()

    def _assess_response(self, response):
        """Assess the quality of student response"""
        # This would contain more sophisticated analysis in a real implementation
        # For now, using a simple keyword-based approach
        key_concepts = {
            "accounting_equation": ["assets", "liabilities", "equity", "balance"],
            "financial_statements": ["balance sheet", "income statement", "cash flow"],
            "financial_ratios": ["ratio", "calculate", "divide", "percentage"]
        }
        
        if self.current_topic:
            relevant_keywords = key_concepts.get(self.current_topic, [])
            matches = sum(keyword in response.lower() for keyword in relevant_keywords)
            return "good" if matches >= 2 else "needs_guidance"
        return "needs_guidance"

    def _provide_guided_hint(self):
        """Provides a structured hint based on current topic and progress"""
        if self.current_topic and self.current_question_index < len(self.topic_hints[self.current_topic]):
            return (f"Let's think about this differently. "
                   f"{self.topic_hints[self.current_topic][self.current_question_index]}")
        return "Could you explain your thinking process to me?"

    def check_prerequisites(self, topic):
        """Checks if student has necessary prerequisite knowledge"""
        prerequisites = {
            "financial_statements": ["accounting_equation", "basic_transactions"],
            "financial_ratios": ["financial_statements"],
            "npv_calculation": ["time_value_money", "cash_flows"]
        }
        
        if topic in prerequisites:
            return prerequisites[topic]
        return []

    def create_practice_problem(self, topic, difficulty):
        """Generates a practice problem based on topic and difficulty"""
        # This would contain a database of problems or a problem generator
        # Simplified version shown here
        practice_problems = {
            "accounting_equation": {
                "easy": "A company purchases $1,000 of inventory on credit. How does this affect the accounting equation?",
                "medium": "A company issues $5,000 in common stock and purchases equipment worth $3,000 cash. Show the impact on the accounting equation.",
                "hard": "A company takes out a $10,000 loan, purchases inventory for $7,000, and pays $2,000 in dividends. What's the net effect on the accounting equation?"
            }
        }
        
        return practice_problems.get(topic, {}).get(difficulty, "No problem available for this topic and difficulty level.")

def main():
    tutor = AccountingFinanceTutor()
    print(tutor.greet_student())
    
    while True:
        user_input = input("\nStudent: ").lower()
        
        if user_input == "exit":
            print("Tutor: Thank you for studying with me! Keep up the good work!")
            break
        
        # Enhanced response handling
        if "help" in user_input or "start" in user_input:
            for topic in tutor.question_sequences.keys():
                if topic in user_input:
                    print("Tutor:", tutor.start_topic_discussion(topic))
                    break
            else:
                print("Tutor: What specific topic would you like to work on? "
                      "I can help with accounting equations, financial statements, or financial ratios.")
        else:
            print("Tutor:", tutor.evaluate_response(user_input, tutor.current_topic))

if __name__ == "__main__":
    main()
